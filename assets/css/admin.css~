/**
 * BWS Taxonomy Manager Admin Styles
 */

/* Main Settings Page Layout */
.bws-taxonomy-manager-tabs {
    margin-top: 20px;
}

.bws-taxonomy-manager-tabs .nav-tab-wrapper {
    border-bottom: 1px solid #ccd0d4;
    margin-bottom: 20px;
}

.bws-taxonomy-manager-tabs .tab-content {
    background: #fff;
    border: 1px solid #ccd0d4;
    border-top: 0;
    padding: 20px;
    min-height: 400px;
}

.bws-taxonomy-manager-tabs .tab-content.active {
    display: block;
}

/* Rules Section Styling */
.bws-rules-section {
    margin-bottom: 30px;
}

.bws-rules-section h2 {
    margin-top: 0;
    margin-bottom: 10px;
    color: #23282d;
    font-size: 1.3em;
}

.bws-rules-section > p {
    margin-bottom: 20px;
    color: #666;
    font-style: italic;
}

/* Individual Rule Item Styling */
.bws-rule-item {
    background: #f9f9f9;
    border: 1px solid #ddd;
    border-radius: 4px;
    margin-bottom: 15px;
    transition: all 0.3s ease;
}

.bws-rule-item:hover {
    border-color: #0073aa;
    box-shadow: 0 2px 4px rgba(0, 115, 170, 0.1);
}

.bws-rule-item.disabled {
    opacity: 0.6;
    background: #f5f5f5;
}

/* Rule Header */
.bws-rule-header {
    background: #fff;
    border-bottom: 1px solid #ddd;
    padding: 12px 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-radius: 4px 4px 0 0;
}

.bws-rule-header label {
    margin: 0;
    font-weight: 600;
    color: #23282d;
}

.bws-rule-header .delete-rule {
    color: #a00;
    text-decoration: none;
    font-size: 12px;
    padding: 4px 8px;
    border-radius: 3px;
    transition: all 0.2s ease;
}

.bws-rule-header .delete-rule:hover {
    background: #a00;
    color: #fff;
}

/* Rule Content */
.bws-rule-content {
    padding: 15px;
}

.bws-rule-content .form-table {
    margin: 0;
}

.bws-rule-content .form-table th {
    width: 200px;
    padding: 15px 10px 15px 0;
    font-weight: 600;
}

.bws-rule-content .form-table td {
    padding: 15px 0;
}

.bws-rule-content select,
.bws-rule-content input[type="text"],
.bws-rule-content input[type="date"] {
    min-width: 200px;
    max-width: 400px;
}

.bws-rule-content label {
    display: block;
    margin-bottom: 5px;
}

.bws-rule-content small {
    color: #666;
    font-style: italic;
}

/* Add Rule Button */
.add-rule-btn,
button[id*="add-"][id*="-rule"] {
    background: #0073aa;
    color: #fff;
    border: none;
    padding: 10px 15px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    margin-top: 15px;
    transition: background 0.2s ease;
}

.add-rule-btn:hover,
button[id*="add-"][id*="-rule"]:hover {
    background: #005a87;
}

/* Process Existing Posts Button */
.process-existing-btn {
    background: #00a32a;
    color: #fff;
    border: none;
    padding: 8px 12px;
    border-radius: 3px;
    cursor: pointer;
    font-size: 13px;
    margin-left: 10px;
    transition: background 0.2s ease;
}

.process-existing-btn:hover {
    background: #008a20;
}

.process-existing-btn:disabled {
    background: #ccc;
    cursor: not-allowed;
}

.process-existing-btn.error {
    background: #d63638;
}

/* Validation Messages */
.validation-message {
    margin: 10px 0;
    padding: 8px 12px;
    border-radius: 4px;
    font-size: 14px;
}

.validation-message.error {
    background: #fff2f2;
    border: 1px solid #d63638;
    color: #d63638;
}

.validation-message.success {
    background: #f0f6fc;
    border: 1px solid #00a32a;
    color: #00a32a;
}

/* Form Field Groups */
.field-group {
    border: 1px solid #ddd;
    border-radius: 4px;
    padding: 15px;
    margin-bottom: 15px;
    background: #fafafa;
}

.field-group h4 {
    margin-top: 0;
    margin-bottom: 10px;
    color: #23282d;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* Radio Button Groups */
.radio-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.radio-group label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0;
}

/* Checkbox Groups */
.checkbox-group {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 10px;
    margin-top: 10px;
}

.checkbox-group label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0;
}

/* Date Range Fields */
.date-range {
    display: flex;
    align-items: center;
    gap: 15px;
    flex-wrap: wrap;
}

.date-range label {
    margin: 0;
    font-weight: 600;
}

.date-range input[type="date"] {
    min-width: 150px;
}

/* Settings Summary */
.settings-summary {
    background: #f0f6fc;
    border: 1px solid #c3c4c7;
    border-radius: 4px;
    padding: 15px;
    margin-bottom: 20px;
}

.settings-summary h3 {
    margin-top: 0;
    margin-bottom: 10px;
    color: #1d2327;
}

.settings-summary .summary-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 5px 0;
    border-bottom: 1px solid #e0e0e0;
}

.settings-summary .summary-item:last-child {
    border-bottom: none;
}

.settings-summary .summary-value {
    font-weight: 600;
    color: #0073aa;
}

/* Status Indicators */
.status-indicator {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-right: 8px;
}

.status-indicator.active {
    background: #00a32a;
}

.status-indicator.inactive {
    background: #ddd;
}

.status-indicator.warning {
    background: #dba617;
}

.status-indicator.error {
    background: #d63638;
}

/* Responsive Design */
@media (max-width: 768px) {
    .bws-rule-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
    }
    
    .bws-rule-content .form-table th,
    .bws-rule-content .form-table td {
        display: block;
        width: 100%;
        padding: 10px 0;
    }
    
    .bws-rule-content .form-table th {
        font-weight: 600;
        border-bottom: 1px solid #ddd;
        margin-bottom: 5px;
    }
    
    .checkbox-group {
        grid-template-columns: 1fr;
    }
    
    .date-range {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
    }
}

/* Loading States */
.loading {
    position: relative;
    pointer-events: none;
}

.loading::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255, 255, 255, 0.8);
    display: flex;
    align-items: center;
    justify-content: center;
}

.loading::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 20px;
    height: 20px;
    margin: -10px 0 0 -10px;
    border: 2px solid #0073aa;
    border-radius: 50%;
    border-top-color: transparent;
    animation: spin 1s linear infinite;
    z-index: 1;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* Tooltips */
.tooltip {
    position: relative;
    cursor: help;
}

.tooltip::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: #1d2327;
    color: #fff;
    padding: 8px 12px;
    border-radius: 4px;
    font-size: 12px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    z-index: 1000;
}

.tooltip:hover::after {
    opacity: 1;
}

/* Admin Columns Integration */
.ac-column.bws-managed {
    position: relative;
}

.ac-column.bws-managed::after {
    content: '⚙';
    position: absolute;
    top: 2px;
    right: 2px;
    font-size: 10px;
    color: #0073aa;
    opacity: 0.7;
}

/* Quick Edit Enhancements */
.quick-edit-bws-notice {
    background: #f0f6fc;
    border: 1px solid #0073aa;
    border-radius: 3px;
    padding: 8px 12px;
    margin: 10px 0;
    font-size: 12px;
    color: #0073aa;
}

/* General Settings */
.general-settings-section {
    background: #fff;
    border: 1px solid #ccd0d4;
    border-radius: 4px;
    padding: 20px;
    margin-bottom: 20px;
}

.general-settings-section h3 {
    margin-top: 0;
    margin-bottom: 15px;
    color: #1d2327;
    border-bottom: 1px solid #ddd;
    padding-bottom: 10px;
}

.conflict-handling-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 15px;
}

.conflict-handling-table th,
.conflict-handling-table td {
    padding: 12px;
    text-align: left;
    border-bottom: 1px solid #ddd;
}

.conflict-handling-table th {
    background: #f9f9f9;
    font-weight: 600;
}

.conflict-handling-table select {
    width: 100%;
    min-width: 120px;
}
